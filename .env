HTTP_PORT=8082

# 0=debug, 1=info, 2=warn, 3=error
LOG_LEVEL=0
LOG_FORMAT=json

# Docker Compose Postgres
POSTGRES_DB=orgstructure
POSTGRES_USER=orguser
POSTGRES_PASSWORD=orgpass
POSTGRES_PORT=5432

# App DB connection
DB_URL=postgres://orguser:orgpass@postgres:5432/orgstructure?sslmode=disable

# Rate limit
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
