# Local (non-Docker) overrides.
#
# Copy to .env.local to run the API directly on the host machine:
#   go run ./cmd
#
# Pick any free port (docker-compose default uses 8082).
HTTP_PORT=8083
#
# With docker-compose, Postgres is exposed on the host as 5435 (see docker-compose.yml).
DB_URL=postgres://orguser:orgpass@localhost:5435/orgstructure?sslmode=disable

# Seed 10 sample rows on start (only if DB is empty).
DB_SEED=1
